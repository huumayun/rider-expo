{
  "expo": {
    "name": "Rider",
    "slug": "graam-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "graamrider",
    "splash": {
      "image": "./assets/splash-new.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grambaazar.rider",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Required for background delivery tracking.",
        "NSLocationWhenInUseUsageDescription": "Required to track your location during deliveries.",
        "NSCameraUsageDescription": "Required to capture delivery proof photos.",
        "NSPhotoLibraryUsageDescription": "Required to pick photos for delivery proof.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070f"
      },
      "package": "com.grambaazar.rider",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCOAksn-Wl4MHYa3WRu5kGPf_h1uLIb60U"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Rider to use your location for delivery tracking.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#22d47a",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Rider to access photos for delivery proof.",
          "cameraPermission": "Allow Rider to use camera for delivery proof."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Rider to access camera."
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "28c972dc-3166-4c51-b8ab-32a62765779a"
      },
      "router": {
        "origin": false
      }
    }
  }
}
